# Forgejo instance URL (internal Docker network address)
FORGEJO_URL=http://forgejo:3000

# API token for the smithy bot user (from setup_instance.py)
SMITHY_FORGEJO_TOKEN=

# API token for architect bot user (from setup_instance.py)
ARCHITECT_FORGEJO_TOKEN=

# Authenticate Claude Code sessions with EITHER an OAuth token OR an API key.
# OAuth token (from `claude setup-token`)
CLAUDE_CODE_OAUTH_TOKEN=
# Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Set CODEX_ENABLED=true to use Codex instead of Claude Code.
CODEX_ENABLED=false
# OpenAI API key used by Codex when CODEX_ENABLED=true
OPENAI_API_KEY=
# Optional Codex model override; leave blank to use the Codex CLI default.
CODEX_MODEL=

# Docker network that task containers attach to
DOCKER_NETWORK=forgejo-net

# Pre-built task container image (from ghcr.io)
TASK_IMAGE=ghcr.io/smithy-ai/claude-task-default:dev

# Tag for smithy-ai images (orchestrator, knowledgebase).
# Use "dev" for latest main-branch builds, or a semver tag like "v1.0.0".
IMAGE_TAG=dev

# HMAC secret for verifying Forgejo webhook signatures
WEBHOOK_SECRET=

# Registration token for Forgejo Actions runner (from setup_instance.py)
RUNNER_TOKEN=

# Comma-separated list of cache volume types to mount in task containers.
# Available types: pnpm, npm, maven, gradle
CACHE_VOLUMES=pnpm,npm

# Browser-reachable Forgejo URL 
FORGEJO_EXTERNAL_URL=http://localhost:3000
