# =============================================================================
# Smithy-AI Deployment Configuration
# =============================================================================
# Copy to .env and fill in your values:   cp .env.example .env
# Required fields are marked [REQUIRED].
# =============================================================================

# --- Hostname -----------------------------------------------------------------
# [REQUIRED] Public hostname for HTTPS (Caddy auto-provisions Let's Encrypt cert)
SMITHY_HOST=smithy.example.com

# --- Provider Selection -------------------------------------------------------
# "gitlab" or "forgejo"
VCS_PROVIDER=gitlab

# --- GitLab Configuration (when VCS_PROVIDER=gitlab) -------------------------
GITLAB_URL=https://gitlab.com
GITLAB_EXTERNAL_URL=https://gitlab.com
# Token type: "oauth2" for group/project tokens, "private-token" for PAT/impersonation
GITLAB_TOKEN_TYPE=oauth2
# [REQUIRED] Access tokens for the bot users
SMITHY_GITLAB_TOKEN=
ARCHITECT_GITLAB_TOKEN=
# [REQUIRED] HMAC secret for verifying GitLab webhook signatures
GITLAB_WEBHOOK_SECRET=

# --- Forgejo Configuration (when VCS_PROVIDER=forgejo) -----------------------
# FORGEJO_URL=https://forgejo.example.com
# FORGEJO_EXTERNAL_URL=https://forgejo.example.com
# SMITHY_FORGEJO_TOKEN=
# ARCHITECT_FORGEJO_TOKEN=
# WEBHOOK_SECRET=

# --- Claude -------------------------------------------------------------------
# [REQUIRED] OAuth token from `claude setup-token`
CLAUDE_CODE_OAUTH_TOKEN=

# --- Bot Users ----------------------------------------------------------------
# Usernames of the bot accounts in your git provider
SMITHY_BOT_USER=smithy
ARCHITECT_BOT_USER=architect
# SMITHY_BOT_EMAIL=
# ARCHITECT_BOT_EMAIL=

# --- Docker -------------------------------------------------------------------
DOCKER_NETWORK=smithy-net
TASK_IMAGE=ghcr.io/smithy-ai/claude-task-default:dev
CACHE_VOLUMES=pnpm,npm

# --- Image Version ------------------------------------------------------------
# Tag for orchestrator and knowledgebase images: "dev", "latest", or a semver
IMAGE_TAG=dev

# --- Knowledgebase (optional) -------------------------------------------------
# Uncomment these lines and set KNOWLEDGEBASE_ENABLED=true to enable.
# COMPOSE_PROFILES=knowledgebase
# KNOWLEDGEBASE_ENABLED=true
# OPENAI_API_KEY=
# KB_VCS_URL=          # same as GITLAB_URL or FORGEJO_URL
# KB_VCS_TOKEN=        # same as SMITHY_GITLAB_TOKEN or SMITHY_FORGEJO_TOKEN
# KB_WEBHOOK_SECRET=   # same as GITLAB_WEBHOOK_SECRET or WEBHOOK_SECRET
