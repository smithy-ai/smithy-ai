# =============================================================================
# Secret knowledgebase configuration (becomes a Kubernetes Secret).
# Only needed if you enable the knowledgebase component.
# Copy to knowledgebase.secret.env and fill in — DO NOT COMMIT the real file.
#     cp knowledgebase.secret.env.example knowledgebase.secret.env
# =============================================================================

# Embeddings provider key
OPENAI_API_KEY=

# The context repo git server (usually same as GITLAB_URL / FORGEJO_URL)
VCS_URL=
# Token with read access to the context repositories
VCS_TOKEN=
# HMAC secret for verifying the git provider's re-index webhooks
WEBHOOK_SECRET=
