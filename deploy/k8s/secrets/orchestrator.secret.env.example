# =============================================================================
# Secret orchestrator configuration (becomes a Kubernetes Secret).
# Copy to orchestrator.secret.env and fill in — DO NOT COMMIT the real file.
#     cp orchestrator.secret.env.example orchestrator.secret.env
# Leave keys for providers you don't use empty; they are harmless.
# =============================================================================

# --- Claude: set EITHER an OAuth token OR an Anthropic API key ----------------
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=

# --- GitLab tokens ------------------------------------------------------------
SMITHY_GITLAB_TOKEN=
ARCHITECT_GITLAB_TOKEN=
GITLAB_WEBHOOK_SECRET=

# --- Forgejo tokens -----------------------------------------------------------
SMITHY_FORGEJO_TOKEN=
ARCHITECT_FORGEJO_TOKEN=
WEBHOOK_SECRET=

# --- GitHub tokens ------------------------------------------------------------
SMITHY_GITHUB_TOKEN=
ARCHITECT_GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# --- Dashboard admin ----------------------------------------------------------
# bcrypt hash of the admin password. Empty -> a random password is logged at startup.
ADMIN_PASSWORD_HASH=
