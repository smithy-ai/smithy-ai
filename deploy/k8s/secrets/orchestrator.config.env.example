# =============================================================================
# Non-secret orchestrator configuration (becomes a ConfigMap).
# Copy to orchestrator.config.env and edit:
#     cp orchestrator.config.env.example orchestrator.config.env
# =============================================================================

# --- Provider selection: "gitlab", "forgejo", or "github" --------------------
VCS_PROVIDER=gitlab

# --- Docker-in-Docker wiring (leave as-is unless you know why) ----------------
# Points the orchestrator's `docker` CLI at the dind sidecar in the same pod.
DOCKER_HOST=tcp://127.0.0.1:2375
DOCKER_NETWORK=smithy-net
TASK_IMAGE=ghcr.io/smithy-ai/claude-task-default:dev
CACHE_VOLUMES=pnpm,npm

# --- GitLab (when VCS_PROVIDER=gitlab) ---------------------------------------
GITLAB_URL=https://gitlab.com
GITLAB_EXTERNAL_URL=https://gitlab.com
GITLAB_TOKEN_TYPE=oauth2

# --- Forgejo (when VCS_PROVIDER=forgejo) -------------------------------------
# FORGEJO_URL=https://forgejo.example.com
# FORGEJO_EXTERNAL_URL=https://forgejo.example.com

# --- GitHub (when VCS_PROVIDER=github) ---------------------------------------
# GITHUB_URL=                 # empty for github.com; set for GitHub Enterprise
# GITHUB_EXTERNAL_URL=

# --- Bot users ----------------------------------------------------------------
SMITHY_BOT_USER=smithy
ARCHITECT_BOT_USER=architect
# SMITHY_BOT_EMAIL=
# ARCHITECT_BOT_EMAIL=

# --- Knowledgebase ------------------------------------------------------------
# Set to true AND enable the knowledgebase component in ../kustomization.yaml.
KNOWLEDGEBASE_ENABLED=false
KNOWLEDGEBASE_URL=http://knowledgebase:8000/mcp
