# Forgejo instance URL (internal Docker network address)
FORGEJO_URL=http://forgejo:3000

# API token for the smithy bot user (from setup_instance.py)
SMITHY_FORGEJO_TOKEN=

# API token for architect bot user (from setup_instance.py)
ARCHITECT_FORGEJO_TOKEN=

# OAuth token for Claude Code sessions (from `claude setup-token`)
CLAUDE_CODE_OAUTH_TOKEN=

# Docker network that task containers attach to
DOCKER_NETWORK=forgejo-net

# Pre-built task container image
TASK_IMAGE=claude-task-default:latest

# HMAC secret for verifying Forgejo webhook signatures
WEBHOOK_SECRET=

# Registration token for Forgejo Actions runner (from setup_instance.py)
RUNNER_TOKEN=

# Comma-separated list of cache volume types to mount in task containers.
# Available types: pnpm, npm, maven, gradle
CACHE_VOLUMES=pnpm,npm

# Browser-reachable Forgejo URL 
FORGEJO_EXTERNAL_URL=http://localhost:3000

