#!/bin/bash
# smithy-init — Container startup initialization.
# Configures git credentials, clones the repo (existing or new branch),
# clones extra repos, and stays running via exec sleep infinity.
#
# Environment variables:
#   VCS_TOKEN       — Token for git credential helper
#   GIT_EMAIL       — Git author email
#   GIT_USERNAME    — Git author name
#   CLONE_URL       — Repository clone URL
#   BRANCH          — Target branch name
#   SOURCE_BRANCH   — Base branch (for new branches)
#   EXTRA_REPOS     — JSON array of [url, dir, branch] tuples (optional)
set -e
trap 'echo "[smithy] FAILED: $BASH_COMMAND" >&2; echo "$BASH_COMMAND" > /tmp/smithy-init-failed; exit 1' ERR

: "${GIT_AUTH_USER:=token}"

echo "[smithy] Configuring git credentials (user: $GIT_AUTH_USER)"
git config --global credential.helper \
  '!f() { echo "username=$GIT_AUTH_USER"; echo "password=$VCS_TOKEN"; }; f'
git config --global user.email "$GIT_EMAIL"
git config --global user.name "$GIT_USERNAME"
git config --global push.autoSetupRemote true

if [ -z "$SOURCE_BRANCH" ]; then
  SOURCE_BRANCH=$(git ls-remote --symref "$CLONE_URL" HEAD \
    | awk '/^ref:/ {sub("refs/heads/", "", $2); print $2; exit}')
  echo "[smithy] Detected default branch from remote: $SOURCE_BRANCH"
fi
if [ -z "$BRANCH" ]; then
  BRANCH="$SOURCE_BRANCH"
fi
echo "$SOURCE_BRANCH" > /tmp/smithy-base-branch

echo "[smithy] Cloning $CLONE_URL (branch: $BRANCH)"
if git clone --filter=blob:none --single-branch --branch "$BRANCH" "$CLONE_URL" /workspace; then
  cd /workspace
  git remote set-branches --add origin "$SOURCE_BRANCH"
  echo "[smithy] Checked out existing branch $BRANCH"
else
  git clone --filter=blob:none --single-branch --branch "$SOURCE_BRANCH" "$CLONE_URL" /workspace
  cd /workspace
  git checkout -b "$BRANCH"
  git remote set-branches --add origin "$BRANCH"
  echo "[smithy] Created new branch $BRANCH from $SOURCE_BRANCH"
fi

# Clone extra repositories (JSON array of [url, dir, branch] tuples)
if [ -n "$EXTRA_REPOS" ] && [ "$EXTRA_REPOS" != "null" ]; then
  echo "[smithy] Cloning extra repositories"
  count=$(echo "$EXTRA_REPOS" | jq 'length')
  i=0
  while [ "$i" -lt "$count" ]; do
    repo_url=$(echo "$EXTRA_REPOS" | jq -r ".[$i][0]")
    repo_dir=$(echo "$EXTRA_REPOS" | jq -r ".[$i][1]")
    repo_branch=$(echo "$EXTRA_REPOS" | jq -r ".[$i][2]")
    if [ -z "$repo_branch" ] || [ "$repo_branch" = "null" ]; then
      repo_branch=""
    fi
    echo "[smithy] Cloning $repo_url -> $repo_dir (branch: ${repo_branch:-<default>})"
    git clone --filter=blob:none "$repo_url" "$repo_dir"
    cd "$repo_dir"
    repo_default=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||' || true)
    if [ -n "$repo_branch" ] && [ "$repo_branch" != "$repo_default" ]; then
      git checkout -b "$repo_branch" || true
    fi
    cd /workspace
    i=$((i + 1))
  done
fi

mkdir -p /tmp/smithy-labels
touch /tmp/smithy-init-done
echo "[smithy] Initialization complete"
exec sleep infinity
